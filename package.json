{
  "name": "aegis-mobile-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@expo/metro-runtime": "^55.0.10",
    "@noble/ciphers": "~2.2.0",
    "@noble/hashes": "~1.8.0",
    "expo": "~54.0.0",
    "expo-application": "~7.0.8",
    "expo-crypto": "~15.0.8",
    "expo-device": "~8.0.10",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-router": "~6.0.0",
    "expo-secure-store": "~15.0.8",
    "expo-sqlite": "~16.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "semver": "^7.5.4",
    "qs": "^6.11.0",
    "tar": "^6.2.1",
    "braces": "^3.0.3",
    "xml2js": "^0.6.2",
    "uuid": "^9.0.0"
  },
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "node",
    "transform": {
      "^.+\\.[jt]sx?$": [
        "babel-jest",
        {
          "presets": [
            "babel-preset-expo"
          ]
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@noble/.*)"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "testMatch": [
      "**/__tests__/**/*.[jt]s?(x)",
      "**/?(*.)+(spec|test).[jt]s?(x)"
    ]
  }
}
